{
  "functions": {
    "api/**/*.js": {
      "includeFiles": "divinoburguer/www.hexadivinosdelivery.site/products/**"
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/divinoburguer/www.hexadivinosdelivery.site/index.html"
    },
    {
      "source": "/cart",
      "destination": "/divinoburguer/www.hexadivinosdelivery.site/cart.html"
    },
    {
      "source": "/cart/",
      "destination": "/divinoburguer/www.hexadivinosdelivery.site/cart.html"
    },
    {
      "source": "/cart.html",
      "destination": "/divinoburguer/www.hexadivinosdelivery.site/cart.html"
    },
    {
      "source": "/cdn/:path*",
      "destination": "/divinoburguer/www.hexadivinosdelivery.site/cdn/:path*"
    },
    {
      "source": "/products/:path*",
      "destination": "/divinoburguer/www.hexadivinosdelivery.site/products/:path*"
    },
    {
      "source": "/collections/:path*",
      "destination": "/divinoburguer/www.hexadivinosdelivery.site/collections/:path*"
    },
    {
      "source": "/pages/:path*",
      "destination": "/divinoburguer/www.hexadivinosdelivery.site/pages/:path*"
    },
    {
      "source": "/json/:path*",
      "destination": "/divinoburguer/www.hexadivinosdelivery.site/json/:path*"
    },
    {
      "source": "/checkouts/:path*",
      "destination": "/divinoburguer/www.hexadivinosdelivery.site/checkouts/:path*"
    },
    {
      "source": "/cdn.shopify.com/:path*",
      "destination": "/divinoburguer/cdn.shopify.com/:path*"
    },
    {
      "source": "/cdnjs.cloudflare.com/:path*",
      "destination": "/divinoburguer/cdnjs.cloudflare.com/:path*"
    },
    {
      "source": "/ajax.googleapis.com/:path*",
      "destination": "/divinoburguer/ajax.googleapis.com/:path*"
    },
    {
      "source": "/unpkg.com/:path*",
      "destination": "/divinoburguer/unpkg.com/:path*"
    },
    {
      "source": "/code.jquery.com/:path*",
      "destination": "/divinoburguer/code.jquery.com/:path*"
    },
    {
