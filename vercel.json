      "destination": "/divinoburguer/size-charts-relentless.herokuapp.com/:path*"
    },
    {
      "source": "/cdn.utmify.com.br/:path*",
      "destination": "/divinoburguer/cdn.utmify.com.br/:path*"
    },
    {
      "source": "/cart.json",
      "destination": "/api/cart"
    },
    {
      "source": "/cart.js",
      "destination": "/api/cart"
    },
    {
      "source": "/cart/add",
      "destination": "/api/cart/add"
    },
    {
      "source": "/cart/add.js",
      "destination": "/api/cart/add"
    },
    {
      "source": "/cart/change.js",
      "destination": "/api/cart/change"
    },
    {
      "source": "/cart/clear.js",
      "destination": "/api/cart/clear"
    },
    {
      "source": "/cart/clear177b.js",
      "destination": "/api/cart/clear"
    },
    {
      "source": "/checkout",
      "destination": "/divinoburguer/checkout.html"
    },
    {
      "source": "/admin",
      "destination": "/divinoburguer/admin.html"
    },
    {
      "source": "/admin.html",
      "destination": "/divinoburguer/admin.html"
    },
    {
      "source": "/checkout.html",
      "destination": "/divinoburguer/checkout.html"
    },
    {
      "source": "/pix",
      "destination": "/divinoburguer/pix.html"
    },
    {
      "source": "/pix.html",
      "destination": "/divinoburguer/pix.html"
    },
    {
      "source": "/.well-known/shopify/monorail/v1/produce",
      "destination": "/api/monorail"
    }
  ]
